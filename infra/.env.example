# Copy to `relay/.env` (and keep it secret — never commit the real value).
#
# Long random secret that locks your relay to the Kith app build. The SAME value
# must be set on the app side (Infra::SelfHosted.relay_token). Leave empty for an
# open relay (no app-level access control). Generate one with:
#   openssl rand -hex 32
IROH_RELAY_ACCESS_TOKEN=replace_with_64_random_hex_chars
